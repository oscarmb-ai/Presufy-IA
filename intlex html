      document.getElementById('r-date').textContent = 'Fecha: ' + now.toLocaleDateString('es-ES',{day:'2-digit',month:'long',year:'numeric'});
      document.getElementById('budget-content').innerHTML = editableHtml;
      recalcTotals();
      currentBudgetData = { empresa, contacto, cliente, direccion, trade, bizType, jobs, numPres, date: now.toLocaleDateString('es-ES') };
      document.getElementById('lbar').classList.remove('on');
