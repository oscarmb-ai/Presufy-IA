    `${lineas}\n` +
    `💰 *TOTAL: ${total}*\n\n` +
    `_Presupuesto válido 30 días · Generado con Presufy_`;

  const url = 'https://wa.me/?text=' + encodeURIComponent(msg);
  window.open(url, '_blank');
}

/* ——— ESTADÍSTICAS PERSONALES ——— */
function getMyStats() {
  const saved = JSON.parse(localStorage.getItem('presufy_saved')||'[]');
  const byTrade = { electricista:0, fontanero:0, albanil:0 };
  let totalAmount = 0;
  saved.forEach(b => {
    byTrade[b.trade] = (byTrade[b.trade]||0) + 1;
    const amt = parseFloat((b.total||'0').replace(/[^\d,]/g,'').replace(',','.'));
    if (!isNaN(amt)) totalAmount += amt;
  });
  return { total: saved.length, byTrade, totalAmount: Math.round(totalAmount) };
}

