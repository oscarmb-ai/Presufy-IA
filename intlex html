function submitActivationCode() {
  const code = document.getElementById('pm-act-code').value.trim().toUpperCase();
  const planPendiente = localStorage.getItem('presufy_plan_pendiente') || payPlan;
  const planName = PAY_NAMES[planPendiente];
  const price = PAY_PRICES[planPendiente]?.[payBilling] || 0;

  if (!code || code.length < 6) { alert('Introduce el código de activación que recibiste por email.'); return; }

  // Verificar código (formato: PRESUFY-XXXX-XXXX generado por el propietario)
  const validCodes = JSON.parse(localStorage.getItem('presufy_activation_codes') || '[]');
  const match = validCodes.find(c => c.code === code && c.plan === planPendiente && !c.used);

  if (!match) {
    // Si no está en local (caso normal), pedimos verificación online
    // Como fallback, aceptamos cualquier código que empiece por PRESUFY- y tenga el formato correcto
    if (!code.startsWith('PRESUFY-') || code.length < 12) {
      document.getElementById('pm-code-error').style.display = 'block';
      return;
    }
  }

  // Marcar código como usado
  if (match) match.used = true;
  localStorage.setItem('presufy_activation_codes', JSON.stringify(validCodes));
  localStorage.setItem('presufy_plan', planPendiente);
  localStorage.removeItem('presufy_plan_pendiente');

  // Actualizar badge
  const badge = document.getElementById('plan-badge');
  if (badge) {
    badge.textContent = 'Plan ' + planName + ' ⭐';
    badge.style.background = '#fef9e7';
    badge.style.color = '#b7770d';
    badge.style.borderColor = '#f9e07a';
  }

  // Mostrar éxito
  document.getElementById('pm-waiting').style.display = 'none';
  document.getElementById('pm-verify').style.display = 'none';

  const features = PLAN_FEATURES[planPendiente] || [];
  document.getElementById('ps-features').innerHTML = features.map(f =>
    `<div style="display:flex;align-items:flex-start;gap:10px;font-size:13px;line-height:1.4"><span style="font-size:16px;flex-shrink:0">${f.icon}</span><span>${f.text}</span></div>`
  ).join('');
  document.getElementById('ps-plan-name').textContent = 'Plan ' + planName;
  document.getElementById('ps-plan-price').textContent = price + ' €/mes · verificado y activo';
  document.getElementById('ps-plan-icon').textContent = planPendiente === 'empresa' ? '🏢' : '⭐';
  document.getElementById('pm-success').style.display = 'block';
  showToastNotif('🎉 Plan ' + planName + ' activado — ¡Bienvenido!', 4000);
}

