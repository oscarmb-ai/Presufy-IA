<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Presufy — Presupuestos con IA</title>
<meta name="theme-color" content="#2d6a2d">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-title" content="Presufy">
<style id="dark-mode-style"></style>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root{--bg:#f7f8f5;--white:#fff;--border:#e2e5d8;--accent:#2d6a2d;--alight:#e8f4e8;--amid:#4a9e4a;--text:#1a1f17;--muted:#6b7260;--danger:#c0392b;--r:12px;--rs:8px;--sh:0 2px 12px rgba(0,0,0,.07)}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:'Inter',sans-serif;background:var(--bg);color:var(--text);font-size:15px;line-height:1.6}
header{background:var(--white);border-bottom:1px solid var(--border);padding:0 2rem;display:flex;align-items:center;justify-content:space-between;height:60px;position:sticky;top:0;z-index:100;box-shadow:0 1px 8px rgba(0,0,0,.06)}
.logo{font-family:'Syne',sans-serif;font-weight:800;font-size:22px;color:var(--accent);display:flex;align-items:center;gap:8px}
.logo-dot{width:8px;height:8px;background:var(--amid);border-radius:50%}
nav a{color:var(--muted);font-size:14px;text-decoration:none;padding:7px 14px;border-radius:var(--rs);transition:.15s}
nav a:hover{background:var(--alight);color:var(--accent)}
.btn-cta{background:var(--accent);color:#fff;font-weight:600;font-size:14px;border:none;cursor:pointer;padding:9px 20px;border-radius:var(--rs)}
.btn-cta:hover{background:var(--amid)}
.hero{text-align:center;padding:72px 2rem 60px;background:var(--white);border-bottom:1px solid var(--border)}
.hero-chip{display:inline-block;background:var(--alight);color:var(--accent);font-size:12px;font-weight:600;padding:5px 14px;border-radius:100px;margin-bottom:24px}
.hero h1{font-family:'Syne',sans-serif;font-weight:800;font-size:clamp(30px,5vw,58px);line-height:1.08;letter-spacing:-1.5px;max-width:700px;margin:0 auto 20px}
.hero h1 em{color:var(--accent);font-style:normal}
.hero p{color:var(--muted);font-size:17px;max-width:480px;margin:0 auto 36px;font-weight:300}
.hero-btns{display:flex;gap:10px;justify-content:center;flex-wrap:wrap}
.btn-hero{background:var(--accent);color:#fff;font-weight:600;font-size:15px;border:none;cursor:pointer;padding:13px 30px;border-radius:var(--rs);transition:.2s}
.btn-hero:hover{background:var(--amid);transform:translateY(-1px)}
.btn-ghost{background:transparent;color:var(--text);font-weight:500;font-size:15px;border:1px solid var(--border);cursor:pointer;padding:13px 30px;border-radius:var(--rs);transition:.2s}
.btn-ghost:hover{border-color:var(--accent);color:var(--accent);background:var(--alight)}
.sstats{display:flex;justify-content:center;background:var(--accent);flex-wrap:wrap}
.sstat{padding:20px 40px;text-align:center;border-right:1px solid rgba(255,255,255,.2)}
.sstat:last-child{border-right:none}
.sstat-n{font-family:'Syne',sans-serif;font-weight:800;font-size:24px;color:#fff;display:block}
.sstat-l{font-size:12px;color:rgba(255,255,255,.7)}
.main{max-width:1040px;margin:0 auto;padding:48px 2rem 80px}
.sh{display:flex;align-items:center;gap:10px;margin-bottom:24px}
.sbadge{background:var(--accent);color:#fff;font-family:'Syne',sans-serif;font-weight:800;font-size:13px;width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.stitle{font-family:'Syne',sans-serif;font-weight:700;font-size:18px}
.ssub{font-size:13px;color:var(--muted);margin-left:auto}
/* MAIN TABS */
.main-tabs{display:flex;gap:0;margin-bottom:32px;border-bottom:2px solid var(--border)}
.main-tab{background:none;border:none;padding:12px 20px;font-family:'Syne',sans-serif;font-weight:700;font-size:14px;color:var(--muted);cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-2px;transition:.15s;display:flex;align-items:center;gap:7px}
.main-tab:hover{color:var(--text)}
.main-tab.on{color:var(--accent);border-bottom-color:var(--accent)}
.tab-pane{display:none}.tab-pane.on{display:block}
/* PROFILE PANEL */
.profile-saved-tag{display:inline-flex;align-items:center;gap:5px;background:var(--alight);color:var(--accent);font-size:11px;font-weight:600;padding:3px 10px;border-radius:100px;margin-left:8px;opacity:0;transition:.3s}
.profile-saved-tag.show{opacity:1}
.profile-rate-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:4px}
.rate-item{background:var(--bg);border:1px solid var(--border);border-radius:var(--rs);padding:12px 14px}
.rate-item label{display:block;font-size:11px;font-weight:700;color:var(--muted);letter-spacing:.4px;text-transform:uppercase;margin-bottom:6px}
.rate-item input{background:var(--white);border:1px solid var(--border);color:var(--text);border-radius:6px;padding:8px 10px;font-family:'Inter',sans-serif;font-size:14px;font-weight:600;width:100%;outline:none;transition:.15s}
.rate-item input:focus{border-color:var(--amid);box-shadow:0 0 0 2px rgba(45,106,45,.08)}
.tsel{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:36px}
.tc{background:var(--white);border:2px solid var(--border);border-radius:var(--r);padding:20px 16px;text-align:center;cursor:pointer;transition:.2s}
.tc:hover{border-color:var(--amid);background:var(--alight)}
.tc.on{border-color:var(--accent);background:var(--alight)}
.tc.on .tlabel{color:var(--accent)}
.temoji{font-size:30px;display:block;margin-bottom:8px}
.tlabel{font-family:'Syne',sans-serif;font-weight:700;font-size:14px}
.tdesc{font-size:12px;color:var(--muted);margin-top:4px}
.fcard{background:var(--white);border:1px solid var(--border);border-radius:var(--r);padding:24px;margin-bottom:18px;box-shadow:var(--sh)}
.fcard-t{font-family:'Syne',sans-serif;font-weight:700;font-size:15px;margin-bottom:18px;color:var(--accent)}
.fg{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.fl label{display:block;font-size:11px;font-weight:600;color:var(--muted);letter-spacing:.4px;text-transform:uppercase;margin-bottom:5px}
.fl input,.fl textarea{background:var(--bg);border:1px solid var(--border);color:var(--text);border-radius:var(--rs);padding:10px 13px;font-family:'Inter',sans-serif;font-size:14px;transition:.15s;outline:none;width:100%}
.fl input:focus,.fl textarea:focus{border-color:var(--amid);box-shadow:0 0 0 3px rgba(45,106,45,.08);background:var(--white)}
.fl textarea{resize:vertical;min-height:80px}
.jrows{display:flex;flex-direction:column;gap:8px;margin-bottom:10px}
.jrow{display:grid;grid-template-columns:1fr 80px 36px;gap:8px;align-items:center}
.jrow input{background:var(--bg);border:1px solid var(--border);color:var(--text);border-radius:var(--rs);padding:9px 12px;font-family:'Inter',sans-serif;font-size:14px;transition:.15s;outline:none;width:100%}
.jrow input:focus{border-color:var(--amid);background:var(--white)}
.brm{background:#fef2f2;border:1px solid #fecaca;color:var(--danger);width:36px;height:38px;border-radius:var(--rs);cursor:pointer;font-size:18px;display:flex;align-items:center;justify-content:center;transition:.15s}
.brm:hover{background:#fee2e2}
.badd{background:var(--alight);border:1.5px dashed var(--amid);color:var(--accent);width:100%;padding:9px;border-radius:var(--rs);cursor:pointer;font-size:13px;font-weight:600;transition:.15s}
.badd:hover{background:#d4ecd4}
.bgen{width:100%;background:var(--accent);color:#fff;font-family:'Syne',sans-serif;font-weight:800;font-size:16px;border:none;cursor:pointer;padding:18px;border-radius:var(--rs);transition:.2s;margin-top:8px;display:flex;align-items:center;justify-content:center;gap:10px}
.bgen:hover{background:var(--amid);transform:translateY(-1px);box-shadow:0 6px 20px rgba(45,106,45,.25)}
.bgen:disabled{opacity:.55;cursor:not-allowed;transform:none;box-shadow:none}
.outwrap{display:none;margin-top:32px}
.outwrap.on{display:block}
.lbar{display:none;align-items:center;justify-content:center;gap:14px;padding:48px 0;color:var(--muted);font-size:15px}
.lbar.on{display:flex}
.spin{width:22px;height:22px;border:2.5px solid var(--border);border-top-color:var(--accent);border-radius:50%;animation:spin .75s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
.bdoc{background:var(--white);border:1px solid var(--border);border-radius:var(--r);box-shadow:var(--sh);overflow:hidden}
.btop{background:var(--accent);padding:24px 28px;display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:14px}
.btop-l h2{font-family:'Syne',sans-serif;font-weight:800;font-size:20px;color:#fff;margin-bottom:4px}
.btop-l p{font-size:13px;color:rgba(255,255,255,.75)}
.btop-r{text-align:right}
.bnum{font-family:'Syne',sans-serif;font-weight:800;font-size:13px;color:rgba(255,255,255,.9);letter-spacing:1px}
.bdate{font-size:12px;color:rgba(255,255,255,.65);margin-top:2px}
.bbody{padding:24px 28px}
.igrid{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:24px}
.ibox{background:var(--bg);border-radius:var(--rs);padding:12px 14px;border:1px solid var(--border)}
.ibox-l{font-size:10px;font-weight:700;color:var(--muted);letter-spacing:1px;text-transform:uppercase;margin-bottom:4px}
.ibox-v{font-size:14px;font-weight:500}

/* TOTAL SUMMARY — pegado justo debajo de la tabla */
.tsummary{display:flex;align-items:stretch;border:1px solid var(--border);border-top:none;border-radius:0 0 var(--r) var(--r);overflow:hidden;margin-bottom:20px;background:var(--white)}
.tsummary-item{flex:1;padding:11px 14px;border-right:1px solid var(--border);display:flex;flex-direction:column;gap:2px;min-width:0}
.tsummary-item:last-child{border-right:none;background:var(--accent)}
.tsummary-label{font-size:10px;font-weight:700;letter-spacing:.8px;text-transform:uppercase;color:var(--muted)}
.tsummary-item:last-child .tsummary-label{color:rgba(255,255,255,.7)}
.tsummary-val{font-family:'Syne',sans-serif;font-weight:700;font-size:17px;color:var(--text)}
.tsummary-item:last-child .tsummary-val{color:#fff;font-size:19px}

/* EDIT HINT */
.edit-hint{display:flex;align-items:center;gap:8px;background:#fffbea;border:1px solid #f5e27a;border-radius:var(--rs);padding:10px 14px;margin-bottom:16px;font-size:13px;color:#7a6100}
.edit-hint strong{color:#5a4700}

/* TABLA EDITABLE */
.btable{width:100%;border-collapse:collapse;margin-bottom:0;font-size:13px;border-radius:var(--r) var(--r) 0 0;overflow:hidden}
.btable thead tr{background:var(--accent)}
.btable thead th{padding:10px 12px;text-align:left;font-weight:600;font-size:11px;letter-spacing:.5px;text-transform:uppercase;color:rgba(255,255,255,.9)}
.btable thead th.r{text-align:right}
.btable tbody tr{border-bottom:1px solid var(--border)}
.btable tbody tr:hover{background:#f9faf6}
.btable td{padding:9px 12px;vertical-align:middle}
.btable td.r{text-align:right;font-weight:500}
.cat-r td{background:var(--alight);font-weight:700;font-size:12px;color:var(--accent);padding:7px 12px}
/* Inputs editables dentro de la tabla */
.price-input{background:var(--white);border:1px solid var(--border);color:var(--text);border-radius:6px;padding:5px 8px;font-family:'Inter',sans-serif;font-size:13px;font-weight:500;width:90px;text-align:right;transition:.15s;outline:none}
.price-input:focus{border-color:var(--amid);box-shadow:0 0 0 2px rgba(45,106,45,.1);background:#fff}
.price-input:hover{border-color:var(--amid)}
/* Totals table */
.ttable{width:340px;margin-left:auto;border-collapse:collapse;font-size:14px;margin-bottom:20px}
.ttable tr td{padding:9px 12px;border-bottom:1px solid var(--border)}
.ttable tr td:last-child{text-align:right;font-weight:500}
.ttable .tfinal{background:var(--accent)}
.ttable .tfinal td{color:#fff;font-family:'Syne',sans-serif;font-weight:800;font-size:16px;border-bottom:none}

.conds{background:var(--bg);border-radius:var(--rs);padding:14px 16px;border:1px solid var(--border);font-size:12px;color:var(--muted);line-height:1.7}
.conds strong{color:var(--text)}
.bactions{display:flex;gap:10px;padding:18px 28px;border-top:1px solid var(--border);flex-wrap:wrap}
.bact{background:var(--bg);border:1px solid var(--border);color:var(--text);padding:10px 18px;border-radius:var(--rs);font-weight:600;font-size:13px;cursor:pointer;transition:.15s;display:flex;align-items:center;gap:6px}
.bact:hover{border-color:var(--accent);color:var(--accent);background:var(--alight)}
.bact.g{background:var(--accent);color:#fff;border-color:var(--accent)}
.bact.g:hover{background:var(--amid)}

/* SAVED BUDGETS PANEL */
.saved-panel{background:var(--white);border:1px solid var(--border);border-radius:var(--r);padding:20px 24px;margin-bottom:24px;box-shadow:var(--sh)}
.saved-title{font-family:'Syne',sans-serif;font-weight:700;font-size:15px;color:var(--accent);margin-bottom:14px;display:flex;align-items:center;justify-content:space-between}
.saved-list{display:flex;flex-direction:column;gap:8px}
.saved-item{display:flex;align-items:center;gap:10px;background:var(--bg);border:1px solid var(--border);border-radius:var(--rs);padding:10px 14px;cursor:pointer;transition:.15s}
.saved-item:hover{border-color:var(--accent);background:var(--alight)}
.saved-item-info{flex:1}
.saved-item-name{font-weight:600;font-size:14px}
.saved-item-meta{font-size:12px;color:var(--muted);margin-top:1px}
.saved-item-total{font-family:'Syne',sans-serif;font-weight:700;font-size:15px;color:var(--accent)}
.saved-item-del{background:#fef2f2;border:1px solid #fecaca;color:var(--danger);width:30px;height:30px;border-radius:6px;cursor:pointer;font-size:16px;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:.15s}
.saved-item-del:hover{background:#fee2e2}
.empty-saved{font-size:13px;color:var(--muted);text-align:center;padding:16px 0}

/* SECTIONS */
.how-section{background:var(--white);border-top:1px solid var(--border);border-bottom:1px solid var(--border);padding:60px 2rem}
.how-inner{max-width:1040px;margin:0 auto}
.slabel{font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--accent);margin-bottom:10px}
.sh2{font-family:'Syne',sans-serif;font-weight:800;font-size:clamp(22px,3vw,36px);letter-spacing:-.8px;margin-bottom:36px}
.steps-row{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));border:1px solid var(--border);border-radius:var(--r);overflow:hidden}
.step-box{padding:22px;border-right:1px solid var(--border)}
.step-box:last-child{border-right:none}
.step-n{font-family:'Syne',sans-serif;font-weight:800;font-size:34px;color:var(--alight);line-height:1;margin-bottom:8px}
.step-t{font-family:'Syne',sans-serif;font-weight:700;font-size:14px;margin-bottom:5px}
.step-d{font-size:13px;color:var(--muted);line-height:1.5}
.feat-section{max-width:1040px;margin:0 auto;padding:60px 2rem}
.feat-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:14px;margin-top:30px}
.feat-card{background:var(--white);border:1px solid var(--border);border-radius:var(--r);padding:20px;transition:.2s}
.feat-card:hover{border-color:var(--amid);box-shadow:0 4px 14px rgba(45,106,45,.1)}
.feat-icon{font-size:24px;margin-bottom:8px}
.feat-t{font-family:'Syne',sans-serif;font-weight:700;font-size:14px;margin-bottom:5px}
.feat-d{font-size:13px;color:var(--muted);line-height:1.5}
.price-section{background:var(--white);border-top:1px solid var(--border);padding:60px 2rem}
.price-inner{max-width:1040px;margin:0 auto}
.pgrid{display:grid;grid-template-columns:repeat(auto-fit,minmax(230px,1fr));gap:14px;margin-top:30px}
.pcard{background:var(--bg);border:1.5px solid var(--border);border-radius:var(--r);padding:24px;position:relative}
.pcard.pop{border-color:var(--accent);background:var(--white)}
.pop-b{position:absolute;top:-12px;left:50%;transform:translateX(-50%);background:var(--accent);color:#fff;font-size:11px;font-weight:700;padding:4px 14px;border-radius:100px;white-space:nowrap}
.pname{font-family:'Syne',sans-serif;font-weight:700;font-size:17px;margin-bottom:5px}
.pamt{font-family:'Syne',sans-serif;font-weight:800;font-size:36px;color:var(--accent);line-height:1}
.pper{font-size:13px;color:var(--muted);margin:4px 0 16px}
.plist{list-style:none;margin-bottom:20px}
.plist li{font-size:13px;padding:5px 0;border-bottom:1px solid var(--border);display:flex;gap:8px}
.plist li::before{content:'✓';color:var(--accent);font-weight:700;flex-shrink:0}
.plist li.no::before{content:'×';color:#ccc}
.plist li.no{color:var(--muted)}
.pbtn{width:100%;padding:11px;border-radius:var(--rs);font-weight:700;font-size:14px;cursor:pointer;transition:.15s}
.pbtn-f{background:var(--accent);color:#fff;border:none}
.pbtn-f:hover{background:var(--amid)}
.pbtn-o{background:transparent;color:var(--text);border:1.5px solid var(--border)}
.pbtn-o:hover{border-color:var(--accent);color:var(--accent)}
footer{border-top:1px solid var(--border);padding:32px 2rem;text-align:center;font-size:13px;color:var(--muted)}
footer strong{color:var(--accent)}
footer a{color:var(--muted);text-decoration:none;margin:0 10px}
footer a:hover{color:var(--accent)}
@media(max-width:700px){
  .fg,.tsel,.igrid{grid-template-columns:1fr}
  .ttable{width:100%}
  .fl.full{grid-column:span 1}
  /* Precios — una columna en móvil */
  .pgrid{grid-template-columns:1fr !important}
  .pcard{margin-bottom:4px}
  /* Stats bar */
  .sstats{flex-direction:column}
  .sstat{border-right:none;border-bottom:1px solid rgba(255,255,255,.2);padding:14px 20px}
  .sstat:last-child{border-bottom:none}
  /* Hero */
  .hero{padding:40px 1.2rem 32px}
  .hero h1{font-size:28px}
  /* How section steps */
  .steps-row{grid-template-columns:1fr}
  .step-box{border-right:none;border-bottom:1px solid var(--border)}
  .step-box:last-child{border-bottom:none}
  /* Features grid */
  .feat-grid{grid-template-columns:1fr}
  /* Main tabs scroll horizontal */
  .main-tabs{overflow-x:auto;-webkit-overflow-scrolling:touch}
  .main-tab{white-space:nowrap;padding:12px 14px;font-size:13px}
  /* Trade selector */
  .tsel{grid-template-columns:1fr 1fr}
  /* Budget doc */
  .btop{flex-direction:column;gap:8px}
  .budget-actions,.bactions{flex-wrap:wrap}
  .bact{font-size:12px;padding:8px 12px}
  /* Info grid in budget */
  .igrid{grid-template-columns:1fr}
  /* Payment modal */
  .pgrid{grid-template-columns:1fr}
  /* FAQ section padding */
  #ayuda{padding:40px 1.2rem}
  /* Valoraciones grid */
  #reviews-grid-outer{grid-template-columns:1fr !important}
  /* Price section */
  .price-section{padding:40px 1.2rem}
  .price-inner{padding:0}
  /* How section */
  .how-section{padding:40px 1.2rem}
  /* Feat section */
  .feat-section{padding:40px 1.2rem}
  /* Summary bar */
  .tsummary{flex-direction:column}
  .tsummary-item{border-right:none;border-bottom:1px solid var(--border)}
  .tsummary-item:last-child{border-bottom:none}
  /* Header nav hide on mobile */
  nav{display:none}
  /* Biz type selector */
  #biz-e,#biz-f,#biz-a,#biz-multi{padding:14px 8px}
}
@media print{header,.hero,.sstats,.main>*:not(.outwrap),.how-section,.feat-section,.price-section,footer,.bactions,.edit-hint,.saved-panel,.price-input+.calc-total{display:none!important}.outwrap{display:block!important}.bdoc{box-shadow:none;border:none}.price-input{border:none;background:transparent}}
@media(max-width:500px){
  [style*="minmax(260px"],[style*="minmax(280px"]{grid-template-columns:1fr !important}
  [style*="minmax(160px"]{grid-template-columns:1fr 1fr !important}
}
</style>
</head>
<body>

<header>
  <div class="logo">
    <img src="data:image/png;base64," alt="Presufy" width="42" height="42" style="border-radius:10px;object-fit:cover">
    <span style="font-family:'Syne',sans-serif;font-weight:800;font-size:20px;color:var(--accent);letter-spacing:-0.5px">Presufy</span>
  </div>
  <nav>
    <a href="#como-funciona">Cómo funciona</a>
    <a href="#precios">Precios</a>
    <a href="#ayuda" onclick="document.getElementById('ayuda').scrollIntoView({behavior:'smooth'});return false">Ayuda</a>
    <a href="presufy-admin.html" style="font-size:11px;opacity:.6">Admin</a>
