function saveBudget() {
  if (!currentBudgetData) return;
  const totalStr = document.getElementById('r-total-big').textContent;
  const tableHtml = document.getElementById('budget-content').innerHTML;
  const prices = [];
  document.querySelectorAll('.price-input').forEach(inp => prices.push(inp.value));
  const saved = getSaved();
  const entry = { id: Date.now(), ...currentBudgetData, total: totalStr, tableHtml, prices };
  saved.unshift(entry);
  setSaved(saved.slice(0, 20));
  renderSaved();
  alert('✓ Presupuesto guardado correctamente');
