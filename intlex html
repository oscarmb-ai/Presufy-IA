function _getTableRows() {
  let rows = '';
  document.querySelectorAll('.btable tbody tr').forEach(tr => {
    if (tr.classList.contains('cat-r')) {
      const cat = tr.querySelector('td') ? tr.querySelector('td').textContent.replace(/▸/g,'').trim() : '';
      rows += `<tr><td colspan="5" style="background:#e8f4e8;font-weight:bold;color:#2d6a2d;padding:6pt 10pt">${cat}</td></tr>`;
    } else {
      const tds = tr.querySelectorAll('td');
      if (!tds.length) return;
      let cells = '';
      tds.forEach((td,i) => {
        const inp = td.querySelector('input');
        const val = inp ? inp.value + ' €' : td.textContent.trim();
        cells += `<td style="padding:6pt 10pt;border-bottom:1pt solid #e2e5d8;${i>=3?'text-align:right;font-family:Courier New,monospace':''}">${val}</td>`;
      });
      rows += `<tr>${cells}</tr>`;
    }
  });
  return rows;
}

