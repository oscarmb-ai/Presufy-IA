  if (payMethod === 'paypal') {
    const price = PAY_PRICES[payPlan]?.[payBilling] || 0;
    if (price > 0) {
      localStorage.setItem('presufy_plan_pendiente', payPlan);
      // Abrir PayPal en nueva pestaña
      window.open(PAYPAL_ME, '_blank');
      // Mostrar pantalla de verificación tras el pago
      document.getElementById('pm-form-body').style.display = 'none';
      document.getElementById('pm-verify').style.display = 'block';
      document.getElementById('pm-verify-plan').textContent = PAY_NAMES[payPlan];
      document.getElementById('pm-verify-price').textContent = price + ' €';
      return;
    }
  }

  // ——— VALIDACIÓN (otros métodos) ———
  if (payMethod === 'card') {
    const name = document.getElementById('pm-f-name').value.trim();
    const num  = document.getElementById('pm-f-num').value.replace(/\s/g,'');
    const exp  = document.getElementById('pm-f-exp').value;
    const cvv  = document.getElementById('pm-f-cvv').value;
    if (!name)           { alert('Introduce el nombre de la tarjeta.'); return; }
    if (num.length < 16) { alert('El número de tarjeta no es válido.'); return; }
    if (!exp.includes('/')) { alert('Introduce la caducidad (MM/AA).'); return; }
    if (cvv.length < 3)  { alert('El CVV no es válido.'); return; }
  } else if (payMethod === 'bizum') {
    const ph = document.getElementById('pm-f-bizum').value.replace(/\s/g,'');
    if (ph.length < 9) { alert('Introduce un número de móvil válido.'); return; }
  } else if (payMethod === 'sepa') {
    const iban = document.getElementById('pm-f-iban').value.replace(/\s/g,'');
    if (iban.length < 20) { alert('Introduce un IBAN válido.'); return; }
  }

  const btn = document.getElementById('pm-btn');
  btn.disabled = true;
  btn.innerHTML = '<div style="width:18px;height:18px;border:2.5px solid rgba(255,255,255,.4);border-top-color:#fff;border-radius:50%;animation:spin .7s linear infinite;display:inline-block"></div> Procesando…';

  // ——— RECOGER DATOS ———
  const planName   = PAY_NAMES[payPlan];
  const price      = PAY_PRICES[payPlan]?.[payBilling] || 0;
  const periodo    = payBilling === 'año' ? 'Anual' : 'Mensual';
  const now        = new Date().toLocaleString('es-ES');
  let methodInfo   = '';
  if (payMethod === 'card') {
    const num = document.getElementById('pm-f-num').value;
    methodInfo = 'Tarjeta terminada en ' + num.replace(/\s/g,'').slice(-4);
  } else if (payMethod === 'bizum') {
    methodInfo = 'Bizum: ' + document.getElementById('pm-f-bizum').value;
  } else if (payMethod === 'sepa') {
    methodInfo = 'SEPA/IBAN: ' + document.getElementById('pm-f-iban').value;
  }

  // ——— ENVIAR NOTIFICACIÓN CON FORMSPREE ———
  // SOLO NECESITAS HACER ESTO UNA VEZ:
  // 1. Ve a https://formspree.io y crea cuenta gratis
  // 2. Crea un nuevo "Form" y pon TU email como destino
  // 3. Copia el ID del form (algo como "xpzgkwqr")
  // 4. Reemplaza TUFORMID aquí abajo con ese ID

  const FORMSPREE_ID = 'TUFORMID'; // ← reemplaza con tu ID de Formspree

  try {
    const res = await fetch('https://formspree.io/f/' + FORMSPREE_ID, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify({
        asunto:  '🎉 Nuevo pago Presufy — Plan ' + planName,
        plan:    planName,
        precio:  price + ' €/mes',
        periodo: periodo,
        metodo:  methodInfo,
        fecha:   now
      })
    });
    if (!res.ok) throw new Error('Formspree error ' + res.status);
  } catch(e) {
    console.warn('Notificación no enviada (configura Formspree):', e.message);
  }

  // ——— ACTIVAR PLAN ———
  localStorage.setItem('presufy_plan', payPlan);
  const badge = document.getElementById('plan-badge');
  if (badge) {
    badge.textContent = 'Plan ' + planName + ' ⭐';
    badge.style.background = '#fef9e7';
    badge.style.color = '#b7770d';
    badge.style.borderColor = '#f9e07a';
  }

  // ——— MOSTRAR PANTALLA DE ÉXITO CON DETALLES ———
  const features = PLAN_FEATURES[payPlan] || [];
  const featHtml = features.map(f =>
    `<div style="display:flex;align-items:flex-start;gap:10px;font-size:13px;line-height:1.4">
      <span style="font-size:16px;flex-shrink:0">${f.icon}</span>
      <span>${f.text}</span>
    </div>`
  ).join('');

  document.getElementById('ps-features').innerHTML = featHtml;
  document.getElementById('ps-plan-name').textContent = 'Plan ' + planName;
  document.getElementById('ps-plan-price').textContent = price + ' €/mes · 7 días gratis incluidos';
  document.getElementById('ps-plan-icon').textContent = payPlan === 'empresa' ? '🏢' : '⭐';
  document.getElementById('pm-form-body').style.display = 'none';
  document.getElementById('pm-success').style.display = 'block';

  // Toast en la cabecera
  showToastNotif('🎉 Plan ' + planName + ' activado — ¡Bienvenido!', 4000);

  btn.disabled = false;
  btn.innerHTML = '🔒 <span id="pm-btn-txt">Activar 7 días gratis</span>';
}

