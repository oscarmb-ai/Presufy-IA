      document.getElementById('bdoc-wrap').style.display = 'block';
    }
    document.getElementById('bgen').disabled = false;
  }, 500);
}

/* ——— GENERADOR LOCAL — usa catálogo del usuario por oficio ——— */
function generarPresupuestoLocal(trade, jobs, moHoras, moPrecio, despPrecio, extraMats) {
  const fmt = n => parseFloat(n).toFixed(2);

  function findInCatalog(desc, jobTrade) {
    const catalog = getCatalog(jobTrade || trade);
    if (!catalog.length) return null;
    const d = desc.toLowerCase();
    let match = catalog.find(c => c.name.toLowerCase() === d);
    if (!match) match = catalog.find(c => d.includes(c.name.toLowerCase()) || c.name.toLowerCase().includes(d));
    return match || null;
  }

  let html = `<table class="budget-table"><thead><tr><th>Ref.</th><th>Descripción</th><th>Ud.</th><th>P.Unit €</th><th>Total €</th></tr></thead><tbody>`;

  // ——— TRABAJOS (del catálogo si existen, si no precio 0 para que editen) ———
  html += `<tr class="cat-r"><td colspan="5">▸ TRABAJOS</td></tr>`;
  let ref = 1;
  jobs.forEach(job => {
    const qty = parseInt(job.qty) || 1;
    const jobTrade = job.trade || trade;
    const catItem = findInCatalog(job.desc, jobTrade);
    const pu = catItem ? catItem.price : 0;
    const tradeTag = bizType === 'multi' ? ` <span style="font-size:10px;color:var(--muted)">[${tradeMap[jobTrade]||jobTrade}]</span>` : '';
    const note = catItem ? '' : ' <span style="color:var(--warn);font-size:11px">⚠ edita el precio</span>';
    html += `<tr><td>T-${String(ref++).padStart(2,'0')}</td><td>${job.desc}${tradeTag}${note}</td><td class="qty-cell">${qty}</td><td>${fmt(pu)}</td><td>${fmt(pu*qty)}</td></tr>`;
  });

  // ——— MATERIALES EXTRA ———
  if (extraMats && extraMats.length) {
    html += `<tr class="cat-r"><td colspan="5">▸ MATERIALES ADICIONALES</td></tr>`;
    extraMats.forEach((m, i) => {
      if (!m.desc) return;
      html += `<tr><td>M-${String(i+1).padStart(2,'0')}</td><td>${m.desc}</td><td class="qty-cell">${m.qty||1}</td><td>${fmt(m.pu||0)}</td><td>${fmt((m.pu||0)*(m.qty||1))}</td></tr>`;
    });
  }

  // ——— MANO DE OBRA ———
  if (moHoras > 0 && moPrecio > 0) {
    html += `<tr class="cat-r"><td colspan="5">▸ MANO DE OBRA</td></tr>`;
    html += `<tr><td>H-01</td><td>Mano de obra (${moHoras} h)</td><td class="qty-cell">${moHoras}</td><td>${fmt(moPrecio)}</td><td>${fmt(moHoras*moPrecio)}</td></tr>`;
  }

  // ——— DESPLAZAMIENTO ———
  if (despPrecio > 0) {
    html += `<tr class="cat-r"><td colspan="5">▸ DESPLAZAMIENTO</td></tr>`;
    html += `<tr><td>D-01</td><td>Desplazamiento y medios auxiliares</td><td class="qty-cell">1</td><td>${fmt(despPrecio)}</td><td>${fmt(despPrecio)}</td></tr>`;
  }

  html += `</tbody></table>`;
  html += `<table style="width:340px;margin-left:auto"><tbody><tr><td>Base imponible</td><td>—</td></tr><tr><td>IVA 21%</td><td>—</td></tr><tr><td>TOTAL PRESUPUESTO</td><td>—</td></tr></tbody></table>`;
  return html;
}

