    return;
  }

  list.innerHTML = `
    <div style="display:grid;grid-template-columns:1fr 110px 34px;gap:8px;padding:6px 10px;margin-bottom:2px">
      <span style="font-size:10px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.5px">Material / Trabajo</span>
      <span style="font-size:10px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;text-align:right">Precio €</span>
      <span></span>
    </div>` +
  cat.map(c => `
    <div style="display:grid;grid-template-columns:1fr 110px 34px;gap:8px;align-items:center;background:var(--bg);border:1px solid var(--border);border-radius:var(--rs);padding:8px 10px;margin-bottom:6px;transition:border-color .15s"
         onmouseover="this.style.borderColor='var(--amid)'" onmouseout="this.style.borderColor='var(--border)'">
      <input
        style="background:transparent;border:none;font-size:14px;font-family:Inter,sans-serif;outline:none;width:100%;color:var(--text);transition:background .2s;border-radius:4px;padding:2px 4px"
        value="${c.name.replace(/"/g,'&quot;').replace(/'/g,'&#39;')}"
        onfocus="this.style.background='#fff';this.style.outline='1px solid var(--amid)'"
        onblur="this.style.background='transparent';this.style.outline='none';updateCatItem(${c.id},'name',this.value,this)"
        onkeydown="if(event.key==='Enter'){event.preventDefault();this.blur()}"
        title="Haz clic para editar el nombre">
      <input type="number" min="0" step="0.01"
        style="background:transparent;border:none;font-size:14px;font-family:'Courier New',monospace;font-weight:700;color:var(--accent);text-align:right;outline:none;width:100%;transition:background .2s;border-radius:4px;padding:2px 4px"
        value="${c.price.toFixed(2)}"
        onfocus="this.style.background='#fff';this.style.outline='1px solid var(--amid)'"
        onblur="this.style.background='transparent';this.style.outline='none';updateCatItem(${c.id},'price',this.value,this)"
        onkeydown="if(event.key==='Enter'){event.preventDefault();this.blur()}"
        title="Haz clic para editar el precio">
      <button onclick="deleteCatItem(${c.id})"
        style="background:#fef2f2;border:1px solid #fecaca;color:var(--danger);width:32px;height:32px;border-radius:6px;cursor:pointer;font-size:15px;display:flex;align-items:center;justify-content:center;transition:.15s"
