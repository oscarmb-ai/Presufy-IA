/* ——— MICROPHONE ——— */
let recognition = null, isListening = false;
function toggleMic(targetId) {
  const SR = window.SpeechRecognition || window.webkitSpeechRecognition;
  if (!SR) { alert('Tu navegador no soporta voz. Usa Chrome o Edge.'); return; }
  if (isListening) { recognition && recognition.stop(); return; }
  recognition = new SR();
  recognition.lang = 'es-ES';
  recognition.continuous = false;
  recognition.interimResults = false;
  const btn = document.getElementById('btn-mic-' + targetId);
  btn.textContent = '⏹️';
  btn.style.borderColor = '#e53e3e';
  isListening = true;
  recognition.onresult = e => {
    const txt = e.results[0][0].transcript;
    const el = document.getElementById(targetId);
    if (el) el.value = (el.value ? el.value + ' ' : '') + txt;
  };
  recognition.onend = () => {
    isListening = false;
    btn.textContent = '🎙️';
    btn.style.borderColor = '';
  };
  recognition.onerror = () => {
    isListening = false;
    btn.textContent = '🎙️';
    btn.style.borderColor = '';
  };
  recognition.start();
}

/* ——— CATALOG (Mis precios — por oficio) ——— */
let catTrade = 'electricista';

function catKey(t) { return 'presufy_catalog_' + (t || catTrade); }

function getCatalog(t) {
  try { return JSON.parse(localStorage.getItem(catKey(t)) || '[]'); } catch { return []; }
}

function setCatalog(a, t) {
  try {
    localStorage.setItem(catKey(t || catTrade), JSON.stringify(a));
    return true;
  } catch(e) { console.error('Error guardando catálogo:', e); return false; }
}

function showSaveToast(msg) {
  let toast = document.getElementById('cat-toast');
  if (!toast) {
    toast = document.createElement('div');
    toast.id = 'cat-toast';
    toast.style.cssText = 'position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:var(--accent);color:#fff;padding:10px 20px;border-radius:100px;font-size:13px;font-weight:600;z-index:9999;opacity:0;transition:opacity .3s;pointer-events:none;box-shadow:0 4px 16px rgba(45,106,45,.3)';
    document.body.appendChild(toast);
  }
  toast.textContent = msg || '✓ Guardado';
  toast.style.opacity = '1';
  clearTimeout(toast._t);
  toast._t = setTimeout(() => { toast.style.opacity = '0'; }, 1800);
}

function setCatTrade(t) {
  catTrade = t;
  ['electricista','fontanero','albanil'].forEach(k => {
    const btn = document.getElementById('cptab-'+k);
    if (!btn) return;
    btn.style.background = k === t ? 'var(--accent)' : 'transparent';
    btn.style.color      = k === t ? '#fff' : 'var(--muted)';
  });
  const s = document.getElementById('cat-search');
  if (s) s.value = '';
  renderCatalog();
}

function addCatItem() {
  const nameEl  = document.getElementById('cat-new-name');
  const priceEl = document.getElementById('cat-new-price');
  const name    = nameEl.value.trim();
  const price   = parseFloat(priceEl.value);
  if (!name)      { nameEl.style.border='1.5px solid var(--danger)'; nameEl.focus(); setTimeout(()=>nameEl.style.border='',1500); return; }
  if (isNaN(price)){ priceEl.style.border='1.5px solid var(--danger)'; priceEl.focus(); setTimeout(()=>priceEl.style.border='',1500); return; }
  const cat = getCatalog();
  const item = { id: Date.now(), name, price };
  cat.unshift(item);
  const ok = setCatalog(cat);
  if (ok) {
    nameEl.value = ''; priceEl.value = '';
    nameEl.focus();
    renderCatalog();
    showSaveToast('✓ "' + name + '" guardado');
  } else {
    alert('Error al guardar. Comprueba que el navegador permite almacenamiento local.');
  }
}

function updateCatItem(id, field, value, el) {
  const cat = getCatalog();
  const item = cat.find(c => c.id === id);
  if (!item) return;
  const newVal = field === 'price' ? (parseFloat(value) || 0) : value.trim();
  if (field === 'price' && isNaN(parseFloat(value))) return;
  if (field === 'name' && !newVal) return;
  item[field] = newVal;
  const ok = setCatalog(cat);
  if (ok) {
    showSaveToast('✓ Precio actualizado');
    if (el) { el.style.background='#e8f4e8'; setTimeout(()=>{ el.style.background='transparent'; },600); }
  }
}

function deleteCatItem(id) {
  const cat = getCatalog();
  const item = cat.find(c => c.id === id);
  const name = item ? item.name : '';
  setCatalog(cat.filter(c => c.id !== id));
  renderCatalog();
  showSaveToast('🗑 "' + name + '" eliminado');
}

