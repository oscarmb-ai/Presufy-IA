  const emoji = { electricista:'⚡', fontanero:'🔧', albanil:'🧱' };
  if (countEl) countEl.textContent = all.length + ' elemento' + (all.length!==1?'s':'') + ' · ' + emoji[catTrade] + ' ' + catTrade[0].toUpperCase()+catTrade.slice(1);

  if (!cat.length) {
    list.innerHTML = `<div style="text-align:center;padding:32px;color:var(--muted);font-size:14px;line-height:1.6">
      ${q ? '🔍 Sin resultados para "<strong>'+q+'</strong>"' :
        '📋 Aún vacío.<br>Añade tu primer precio de <strong>'+catTrade+'</strong> arriba ↑'}
