/* ——— RECALCULATE TOTALS ——— */
function recalcTotals() {
  // Los precios introducidos YA incluyen IVA
  // El total = suma de (precio_con_iva × cantidad)
  // Base imponible = total / 1.21
  // IVA (21%) = total - base  →  se muestra solo como desglose informativo, NO se suma

  let totalConIVA = 0;
  const fmtES = n => n.toLocaleString('es-ES',{minimumFractionDigits:2,maximumFractionDigits:2});

  document.querySelectorAll('.row-total').forEach(cell => {
    const row = cell.closest('tr');
    if (!row || row.classList.contains('cat-r')) return;
    const puInput = row.querySelector('.price-input');
    const qtyCell = row.querySelector('.qty-cell');
    if (puInput && qtyCell) {
      const pu  = parseFloat(puInput.value.replace(',','.')) || 0;
      const qty = parseFloat(qtyCell.textContent) || 1;
      const rowTotal = pu * qty;
      totalConIVA += rowTotal;
      cell.textContent = fmtES(rowTotal) + ' €';
    }
  });

  // Desglose: los precios ya incluyen IVA
  const base = totalConIVA / 1.21;   // base imponible extraída
  const iva  = totalConIVA - base;   // IVA que ya estaba dentro

  // Actualizar resumen visual
  const rBase    = document.getElementById('r-base');
  const rIvaSum  = document.getElementById('r-iva-sum');
  const rTotalBig= document.getElementById('r-total-big');
  if (rBase)     rBase.textContent     = fmtES(base) + ' €';
  if (rIvaSum)   rIvaSum.textContent   = fmtES(iva)  + ' €';
  if (rTotalBig) rTotalBig.textContent = fmtES(totalConIVA) + ' €';

  return fmtES(totalConIVA) + ' €';
}

/* ——— PARSE AI HTML → editable table ——— */
function makeEditable(html) {
  const tmp = document.createElement('div');
  tmp.innerHTML = html;

  tmp.querySelectorAll('table').forEach(tbl => {
    tbl.classList.add('btable');
    tbl.querySelectorAll('tr').forEach(tr => {
      const tds = tr.querySelectorAll('td');
      if (!tds.length) return;
      if (tr.classList.contains('cat-r') || (tds.length === 1 && tds[0].getAttribute('colspan'))) return;
      if (tds.length >= 4) {
        const puCell = tds[tds.length - 2];
        const totalCell = tds[tds.length - 1];
        const qtyCell = tds.length >= 5 ? tds[tds.length - 3] : null;
        if (qtyCell) qtyCell.classList.add('qty-cell');
        const rawPU = puCell.textContent.replace(/[€\s]/g,'').replace(',','.');
        const pu = parseFloat(rawPU) || 0;
        puCell.innerHTML = `<input class="price-input" type="number" min="0" step="0.01" value="${pu.toFixed(2)}" oninput="recalcTotals()" aria-label="Precio unitario editable">`;
        totalCell.classList.add('row-total','r');
      }
    });
    tbl.querySelectorAll('th').forEach((th,i,arr) => {
      if (i >= arr.length-2) th.classList.add('r');
    });
  });

  // Remove any secondary totals table the AI generated
  const allTables = tmp.querySelectorAll('table.btable');
  for (let i = 1; i < allTables.length; i++) allTables[i].remove();

  // Insert summary bar immediately after the main table — no gap
  const mainTable = tmp.querySelector('table.btable');
  if (mainTable) {
    mainTable.style.marginBottom = '0';
    const summary = document.createElement('div');
    summary.className = 'tsummary';
    summary.innerHTML =
      '<div class="tsummary-item"><span class="tsummary-label">Base (sin IVA)</span><span class="tsummary-val" id="r-base">—</span><span style="font-size:10px;color:var(--muted);margin-top:1px">desglose informativo</span></div>' +
      '<div class="tsummary-item"><span class="tsummary-label">IVA 21% incluido</span><span class="tsummary-val" id="r-iva-sum">—</span><span style="font-size:10px;color:var(--muted);margin-top:1px">ya dentro del precio</span></div>' +
      '<div class="tsummary-item"><span class="tsummary-label">Total (IVA incluido)</span><span class="tsummary-val" id="r-total-big">—</span><span style="font-size:10px;color:rgba(255,255,255,.7);margin-top:1px">lo que paga el cliente</span></div>';
    mainTable.insertAdjacentElement('afterend', summary);
  }

  return tmp.innerHTML;
}

